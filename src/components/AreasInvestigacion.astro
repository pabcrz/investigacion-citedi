---
import { areas } from "../lib/data";
---

<div
  class="text-fluid-md w-max-content flex flex-wrap gap-2 text-center font-bold justify-center"
>
  {
    areas.map((area) => (
      <a
        href="#"
        class="flex flex-col items-center w-[70%] md:max-w-[30%] px-8 hover:shadow-lg rounded-md py-4"
      >
        <img src={area.img} alt={area.content} class="rounded-md" />
        <div class="rounded-full size-16 bg-[#EBF9F0] flex items-center justify-center -mt-4">
          <img
            src={area.icon}
            alt={area.alt}
            role="img"
            aria-hidden="true"
            class="size-8"
          />
        </div>
        <p>{area.content}</p>
      </a>
    ))
  }
</div>
