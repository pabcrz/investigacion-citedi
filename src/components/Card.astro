---
import { cards } from "../lib/data";
---

<div class="w-max-content flex flex-wrap gap-8 justify-center">
  {
    cards.map((card, i) => (
      <div
        class={`border-4 rounded-3xl p-4 w-80 h-80`}
        style={{
          borderColor: card.color, // Asignar el color al borde
        }}
      >
        <div class="flex flex-col justify-evenly h-full">
          {card.items.map((item, i) => (
            <div class="flex justify-between gap-4 items-center">
              <p
                class={`rounded-full min-w-20 size-20 border flex items-center justify-center text-white text-wrap text-4xl font-bold`}
                style={{
                  backgroundColor: card.color, // Asignar el color como fondo
                }}
              >
                {item.numbers}
              </p>
              <p class="w-auto text-sm" set:html={item.content} />
            </div>
          ))}
        </div>
      </div>
    ))
  }
</div>
