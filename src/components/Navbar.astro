---
import { Image } from "astro:assets";
import logoIPN from "../img/logo-ipn.svg";
import logoCITEDI from "../img/logo_citedi.png";

import { menuItems } from "../lib/data";
---

<nav class="w-full shadow-md h-[4.5rem] flex justify-center">
  <div
    class="w-max-content flex items-center justify-between px-3 md:p-0 text-black"
  >
    <div class="flex gap-2">
      <a href="https://www.ipn.mx/" target="_blank" class="flex items-center">
        <Image src={logoIPN} alt="Logo del IPN" class="size-10 md:size-8" />
      </a>
      <a
        href="https://www.citedi.mx/portal/"
        target="_blank"
        class="flex items-center"
      >
        <Image
          src={logoCITEDI}
          alt="Logo del CITEDI"
          class="w-auto max-h-10 md:max-h-8"
        />
      </a>
    </div>
    <ul class="text-base font-bold hidden lg:block">
      {
        menuItems.map((item) => (
          <li class="inline-block hover:text-primary px-1 rounded group relative">
            <a href={item.url}>{item.title}</a>
            {item.subItems && (
              <ul class="absolute w-60 bg-white shadow-md transition-all ease-in opacity-0 -z-20 rounded-md p-3 group-hover:opacity-100 group-hover:z-10 group-hover:mt-2">
                {item.subItems.map((subItem) => (
                  <li class="hover:opacity-100 hover:z-10 text-black hover:text-primary font-normal">
                    <a href={subItem.url}>{subItem.title}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }

      <!-- <li class="inline-block hover:shadow-lg px-1 rounded">
