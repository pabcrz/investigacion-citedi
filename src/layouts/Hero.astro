---
import { Image } from "astro:assets";
import logoIPN from "/src/img/logo_ipn.webp";
---

<section
  class="w-full bg-hero-pattern bg-center bg-cover min-h-[90vh] flex items-center justify-center"
>
  <div class="w-max-content">
    <Image
      src={logoIPN}
      alt="Logo IPN, la tecnica al servicio de la patria."
      class="h-24 w-auto object-contain"
    />
    <div class="bg-black/50 text-white p-8">
      <h1 class="font-black text-5xl">La Investigación en Citedi</h1>
      <h2 class="font-extrabold text-2xl">
        Centro de Investigación y Desarrollo de Tecnología Digital
      </h2>
    </div>
  </div>
</section>
